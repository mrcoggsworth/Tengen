# ── LLM ────────────────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_google_api_key_here
MODEL_NAME=gemini-2.0-flash

# ── AWS ─────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
# Optional: point to LocalStack for local dev
AWS_ENDPOINT_URL=http://localhost:4566
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789/tengen-alerts

# ── GCP ─────────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project
PUBSUB_PROJECT_ID=your-gcp-project
PUBSUB_SUBSCRIPTION_ID=tengen-alerts-sub
# Optional: point to local Pub/Sub emulator
PUBSUB_EMULATOR_HOST=localhost:8085

# ── Azure ────────────────────────────────────────────────────────────────────
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_SUBSCRIPTION_ID=your-subscription-id

# ── CrowdStrike ──────────────────────────────────────────────────────────────
CROWDSTRIKE_CLIENT_ID=your-cs-client-id
CROWDSTRIKE_CLIENT_SECRET=your-cs-client-secret
CROWDSTRIKE_BASE_URL=https://api.crowdstrike.com

# ── Kubernetes ───────────────────────────────────────────────────────────────
# Leave empty to use in-cluster config or default ~/.kube/config
K8S_KUBECONFIG=

# ── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=tengen
KAFKA_TOPICS=security-events

# ── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# ── Splunk HEC ───────────────────────────────────────────────────────────────
SPLUNK_HEC_URL=https://splunk.example.com:8088
SPLUNK_HEC_TOKEN=your-splunk-hec-token
SPLUNK_INDEX=tengen
SPLUNK_BATCH_SIZE=25

# ── Splunk ES (notable event consumer) ───────────────────────────────────────
SPLUNK_ES_HOST=splunk-es.example.com
SPLUNK_ES_PORT=8089
SPLUNK_ES_TOKEN=your-splunk-es-token
SPLUNK_ES_SEARCH=| search index=notable

# ── Dashboard ────────────────────────────────────────────────────────────────
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080
RABBITMQ_MGMT_URL=http://localhost:15672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# ── Universal HTTP Consumer ───────────────────────────────────────────────────
UNIVERSAL_HTTP_HOST=0.0.0.0
UNIVERSAL_HTTP_PORT=8088
UNIVERSAL_HTTP_TOKEN=your-ingest-bearer-token

# ── External Enrichment ───────────────────────────────────────────────────────
ABUSE_IPDB_KEY=your-abuseipdb-key
VT_API_KEY=your-virustotal-api-key
IPINFO_TOKEN=your-ipinfo-token
SECURITYTRAILS_API_KEY=your-securitytrails-key
OKTA_API_TOKEN=your-okta-api-token
OKTA_DOMAIN=your-org.okta.com
CMDB_ENDPOINT=https://cmdb.example.com/api/v1
CMDB_TOKEN=your-cmdb-token

# ── PagerDuty ────────────────────────────────────────────────────────────────
PAGERDUTY_API_KEY=your-pagerduty-api-key
SIEM_ENDPOINT=https://siem.example.com/api/findings
